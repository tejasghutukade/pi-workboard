{
  "name": "pi-workboard",
  "version": "0.1.0",
  "keywords": ["pi-package"],
  "private": true,
  "type": "module",
  "description": "Pi Workboard extension: durable Jira-style work tracking for pi-coding-agent sessions.",
  "pi": {
    "extensions": ["./index.ts"]
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dashboard": "node dashboard/server.mjs"
  },
  "dependencies": {
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.7",
    "@earendil-works/pi-coding-agent": "^0.80.7",
    "@types/node": "^22.20.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7"
  }
}
